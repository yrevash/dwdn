# ─── Instagram (the dummy account that RECEIVES the reels) ───
IG_USERNAME=your_dummy_username
IG_PASSWORD=your_dummy_password
# 2FA: paste your AUTHENTICATOR-APP secret key here so the bot generates its own
# codes (required for headless re-login). Instagram → Settings → Security →
# Two-factor authentication → Authentication app → copy the "key" / setup key.
IG_TOTP_SEED=
# IG_2FA_CODE=        # optional: one-time 6-digit code for a first manual login

# ─── Cloudflare R2 — SCOPED token for granthvani-reels-inbox ONLY ───
# This token must NOT be your main R2 key. It is scoped to the inbox bucket
# only and physically cannot touch granthvani-cdn.
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=token_access_key_id
R2_SECRET_ACCESS_KEY=token_secret_access_key
R2_BUCKET=granthvani-reels-inbox
R2_PREFIX=reels/

# ─── HEVC transcode (visually transparent compression) ───
TRANSCODE=true
TRANSCODE_CRF=26
TRANSCODE_PRESET=slow

# ─── Runtime ───
DOWNLOAD_DIR=./downloads
POLL_INTERVAL=30
MAX_WORKERS=3
DOWNLOAD_MIN_GAP=8          # min seconds between download STARTS (anti-flag throttle; raise to go slower)
# IG_PROXY=http://user:pass@host:port   # optional; STRONGLY recommended for big backfills

# ─── Scheduled account scraping (runs alongside the DM watcher) ───
# Target accounts live in targets.txt (one @username per line), NOT here.
SCRAPE_ENABLED=true
SCRAPE_BACKFILL=true        # true = crawl each account's FULL reel history (resumable)
SCRAPE_INTERVAL=7200        # seconds between ongoing re-checks once backfilled (7200 = 2h)
SCRAPE_PAGE_SIZE=30         # reels fetched per API page during backfill
SCRAPE_PAGE_DELAY=60        # base seconds between backfill pages (keep slow = safe)
SCRAPE_MAX_PER_ACCOUNT=0    # 0 = unlimited; set e.g. 500 to cap per account
